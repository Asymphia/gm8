{
   "semi": false,
   "singleQuote": false,
   "jsxSingleQuote": false,
   "tabWidth": 3,
   "useTabs": false,
   "bracketSpacing": true,
   "bracketSameLine": false,
   "arrowParens": "avoid",
   "trailingComma": "none",
   "printWidth": 120,
   "proseWrap": "preserve",
   "quoteProps": "as-needed",
   "plugins": ["prettier-plugin-tailwindcss"]
}
